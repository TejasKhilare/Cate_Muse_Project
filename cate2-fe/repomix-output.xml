  white-space:    nowrap;
}

.th.right {
  text-align: right;
}

/* ── Rows ─────────────────────────────────────────────────────── */
.row {
  cursor:     pointer;
  transition: background-color 0.12s ease;
  /* Subtle fade-in animation */
  animation: fadeInRow 0.25s ease both;
}

@keyframes fadeInRow {
  from {
    opacity:   0;
    transform: translateY(4px);
  }
  to {
    opacity:   1;
    transform: translateY(0);
  }
}

.row:hover {
  background-color: #faf9f6;
}

.row:not(:last-child) td {
  border-bottom: 1px solid var(--muse-card-border);
}

/* ── Cells ────────────────────────────────────────────────────── */
.td {
  padding:        clamp(12px, 1.05vw, 20px) clamp(12px, 1.1vw, 20px);
