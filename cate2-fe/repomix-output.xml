  white-space:      nowrap;
  flex-shrink:      0;
  transition:       background 0.15s, transform 0.1s;
  line-height:      1;
}

.newBtn:hover {
  background: var(--muse-gold-dark);
  color:      #1a1f2e;
  transform:  translateY(-1px);
}

.newBtn:active {
  transform: translateY(0);
}

/* ── Table section ───────────────────────────────────────────── */
.tableSection {
  width: 100%;
}

/* Loading state */
.loader {
  display:         flex;
  align-items:     center;
  justify-content: center;
  padding:         80px 0;
  background:      var(--muse-card-bg);
  border:          1px solid var(--muse-card-border);
  border-radius:   var(--muse-card-radius);
}

/* ── Tablet (768–1023px) ──────────────────────────────────────── */
@media (max-width: 1023px) {
  .page {
    gap: 20px;
  }

  .pageTitle {
    font-size: 22px;
  }

  .pageSubtitle {
    font-size: 13px;
  }
}

/* ── Mobile (<768px) ─────────────────────────────────────────── */
@media (max-width: 767px) {
  .page {
    gap: 16px;
  }

  /* Stack header vertically on mobile */
  .pageHeader {
    flex-direction: column;
    align-items:    stretch;
  }

  .newBtn {
    justify-content: center;
    width:           100%;
    padding:         12px 20px;
    font-size:       14px;
  }

  .pageTitle {
    font-size: 20px;
  }
}
</file>

