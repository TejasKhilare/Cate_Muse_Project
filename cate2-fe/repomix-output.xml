}

.td.right {
  text-align: right;
}

/* ── Cell content styles ──────────────────────────────────────── */
.proposalName {
  font-size:   clamp(13px, 0.95vw, 15px);
  font-weight: 600;
  color:       var(--muse-text-primary);
  line-height: 1.3;
}

.clientName {
  font-size: clamp(12px, 0.88vw, 14px);
  color:     var(--muse-text-secondary);
}

.guests {
  font-size:   clamp(12px, 0.88vw, 14px);
  color:       var(--muse-text-primary);
  font-weight: 500;
}

.date {
  font-size:  clamp(12px, 0.88vw, 14px);
  color:      var(--muse-text-secondary);
  white-space: nowrap;
}

/* Value — bold, large values in bold */
.value {
  font-size:   clamp(13px, 0.95vw, 15px);
  font-weight: 700;
  color:       var(--muse-text-primary);
