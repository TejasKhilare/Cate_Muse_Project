/* src/muse/components/layout/MuseTopHeader/MuseTopHeader.module.css */

/* ── Shell ───────────────────────────────────────────────────── */
.header {
  /*
   * clamp(64px, 4.5vw, 90px)
   * At 1024px → 4.5vw = 46px → floors at 64px
   * At 1440px → 4.5vw = 65px → ~64px (reference)
   * At 2560px → 4.5vw = 115px → caps at 90px
   */
  height:        clamp(64px, 4.5vw, 90px);
  background:    var(--muse-header-bg);
  border-bottom: 1px solid var(--muse-header-border);
  display:       flex;
  align-items:   center;
  gap:           clamp(10px, 0.85vw, 20px);
  padding:       0 clamp(20px, 1.8vw, 48px);
  position:      sticky;
  top:           0;
  z-index:       50;
}

/* ── Hamburger ────────────────────────────────────────────────── */
.hamburger {
  display:         none;
  width:           36px;
  height:          36px;
  flex-shrink:     0;
  border:          none;
  background:      transparent;
  border-radius:   8px;
  align-items:     center;
  justify-content: center;
  cursor:          pointer;
  color:           var(--muse-text-secondary);
  transition:      background 0.15s;
}

.hamburger:hover {
  background: #f5f4f0;
}

/* ── Search ──────────────────────────────────────────────────── */
.searchBox {
  flex:          1;
  max-width:     clamp(400px, 32vw, 780px);
  min-width:     0;
  display:       flex;
  align-items:   center;
  gap:           clamp(6px, 0.55vw, 14px);
  height:        clamp(38px, 2.8vw, 56px);
  padding:       0 clamp(10px, 0.9vw, 20px);
  background:    #f9f8f5;
  border:        1px solid #e8e6e0;
  border-radius: clamp(8px, 0.55vw, 12px);
  transition:    border-color 0.15s;
}

.searchBox:focus-within {
  border-color: var(--muse-gold);
}

.searchIcon {
  flex-shrink: 0;
  color:       #9ca3af;
  /*
   * lucide-react icon size is set via prop in TSX (size={15}).
   * We don't scale that here — acceptable at all sizes.
   * If needed, override via font-size trick on SVG.
   */
}

.searchInput {
  flex:               1;
  min-width:          0;
  border:             none;
  outline:            none;
  background:         transparent;
  font-size:          clamp(13px, 0.95vw, 18px);
  color:              var(--muse-text-primary);
  font-family:        inherit;
  appearance:         none;
  -webkit-appearance: none;
}

.searchInput::placeholder {
  color: #9ca3af;
}

.searchInput::-webkit-search-decoration,
.searchInput::-webkit-search-cancel-button,
.searchInput::-webkit-search-results-button,
.searchInput::-webkit-search-results-decoration {
