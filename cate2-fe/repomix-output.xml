/* Fix 2 — scrollWrapper handles BOTH axes with visible scrollbars */
.scrollWrapper {
  overflow-x:                 auto;
  overflow-y:                 auto;   /* vertical scroll here, not on wrapper */
  -webkit-overflow-scrolling: touch;
  flex:                       1;      /* takes remaining height after header */
  min-height:                 0;      /* required for flex child to scroll */

  /* Fix 3 — visible scrollbar on all devices including laptop */
  scrollbar-width:            auto;   /* NOT thin/none — full size scrollbar */
  scrollbar-color:            #c9a84c #f5f4f0;  /* gold thumb, warm bg */
}

/* Webkit (Chrome, Safari, Edge) — styled visible scrollbars */
.scrollWrapper::-webkit-scrollbar {
  width:  8px;   /* vertical scrollbar width */
  height: 8px;   /* horizontal scrollbar height */
}

.scrollWrapper::-webkit-scrollbar-track {
  background:    #f5f4f0;
  border-radius: 4px;
}

.scrollWrapper::-webkit-scrollbar-thumb {
  background:    #c9a84c;  /* gold — matches MUSE brand */
  border-radius: 4px;
  border:        2px solid #f5f4f0;  /* gap between thumb and track */
}

.scrollWrapper::-webkit-scrollbar-thumb:hover {
  background: #a88735;
}

