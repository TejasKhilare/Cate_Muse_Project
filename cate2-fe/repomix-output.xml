<file path="src/muse/pages/DashboardPage/DashboardPage.tsx">
import { useUserStore } from '@/stores/userStore/userStore';
import { useShallow } from 'zustand/react/shallow';
import { useDashboardStats } from '@/muse/hooks/dashboard/useDashboard';
import { MuseLayout }       from '@/muse/components/layout/MuseLayout/MuseLayout';
import { MuseStatCard }     from '@/muse/components/dashboard/MuseStatCard/MuseStatCard';
import { QuickTools }       from '@/muse/components/dashboard/QuickTools/QuickTools';
import { ProposalPipeline } from '@/muse/components/dashboard/ProposalPipeline/ProposalPipeline';
import { UpcomingEvents }   from '@/muse/components/dashboard/UpcomingEvents/UpcomingEvents';
import { MUSE_ROUTES }      from '@/muse/constants/routes';
import { Link }             from 'react-router';
import styles from './DashboardPage.module.css';

export const DashboardPage = () => {
  const { userData } = useUserStore(
    useShallow((s) => ({ userData: s.userData })),
  );

  const { data: stats = [] } = useDashboardStats();

  // First name only for greeting
  const firstName = userData?.name?.split(' ')[0] ?? 'there';

  // Time-based greeting
  const hour     = new Date().getHours();
  const greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

  return (
    <MuseLayout>
      <div className={styles.page}>

        {/* ── Greeting ── */}
        <div className={styles.greeting}>
          <h1 className={styles.greetingTitle}>
            {greeting}, <em>{firstName}</em>
          </h1>
          <p className={styles.greetingSubtitle}>
            You have{' '}
            <strong>3 proposals</strong> awaiting review and{' '}
            <strong>2 events</strong> this week.
          </p>
        </div>

        {/* ── KPI Cards ── */}
        <div className={styles.kpiRow}>
          {stats.map((stat) => (
            <MuseStatCard key={stat.id} stat={stat} />
          ))}
        </div>

        {/* ── Quick Tools ── */}
        <section>
          <div className={styles.sectionHeader}>
            <h2 className={styles.sectionTitle}>Quick Tools</h2>
            <Link to={MUSE_ROUTES.NEW_PROPOSAL} className={styles.sectionLink}>
              New Proposal →
            </Link>
          </div>
          <QuickTools />
        </section>

        {/* ── Bottom row ── */}
        <div className={styles.bottomRow}>
          <div className={styles.pipelineCol}>
            <h2 className={styles.sectionTitle}>Proposal Pipeline</h2>
            <ProposalPipeline />
          </div>
          <div className={styles.eventsCol}>
            <h2 className={styles.sectionTitle}>Upcoming Events</h2>
            <UpcomingEvents />
          </div>
        </div>

      </div>
    </MuseLayout>
  );
};
</file>

<file path="src/muse/pages/EquipmentCalculatorPage/EquipmentCalculatorPage.module.css">
/* src/muse/pages/EquipmentCalculatorPage/EquipmentCalculatorPage.module.css */

.page {
  display:        flex;
  flex-direction: column;
  gap:            clamp(18px, 1.6vw, 28px);
  width:          100%;
}

/* ── Page header ─────────────────────────────────────────────── */
.pageHeader {
  display:         flex;
  align-items:     flex-start;
  justify-content: space-between;
  gap:             16px;
  flex-wrap:       wrap;
}

.pageHeaderLeft {
  display:        flex;
  flex-direction: column;
  gap:            clamp(5px, 0.4vw, 8px);
}

.titleRow {
  display:     flex;
  align-items: center;
  gap:         clamp(10px, 0.85vw, 14px);
}

.pageTitle {
  font-size:   clamp(22px, 1.9vw, 32px);
  font-weight: 700;
  color:       var(--muse-text-primary);
  margin:      0;
  line-height: 1.2;
}

.pageSubtitle {
  font-size:   clamp(12px, 0.88vw, 14px);
  color:       var(--muse-text-secondary);
  margin:      0;
  line-height: 1.5;
}

/* ── Mode selector ───────────────────────────────────────────── */
.modeWrapper {
  flex-shrink: 0;
}

/* ── 2-col layout ────────────────────────────────────────────── */
.layout {
  display:               grid;
  grid-template-columns: clamp(280px, 32vw, 480px) 1fr;
  gap:                   clamp(16px, 1.4vw, 24px);
  align-items:           start;
}

.formCol {
  display:        flex;
  flex-direction: column;
  gap:            clamp(12px, 1vw, 16px);
  min-width:      0;
}

.resultsCol {
  display:        flex;
  flex-direction: column;
  gap:            clamp(12px, 1vw, 16px);
  min-width:      0;
}

/* ── Form section cards ──────────────────────────────────────── */
.section {
  background:     var(--muse-card-bg);
  border:         1px solid var(--muse-card-border);
  border-radius:  var(--muse-card-radius);
  padding:        clamp(16px, 1.4vw, 24px);
  box-shadow:     var(--muse-shadow-card);
  display:        flex;
  flex-direction: column;
  gap:            clamp(12px, 1vw, 16px);
}

.sectionLabel {
  font-size:      clamp(10px, 0.72vw, 11px);
  font-weight:    600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--muse-text-muted);
}

/* ── Field group ─────────────────────────────────────────────── */
.fieldGroup {
  display:        flex;
  flex-direction: column;
  gap:            clamp(5px, 0.4vw, 7px);
}

.fieldLabel {
  font-size:   clamp(12px, 0.85vw, 13px);
  color:       var(--muse-text-secondary);
  font-weight: 400;
}

/* ── Number input ────────────────────────────────────────────── */
.inputNumber {
  width:              100%;
  height:             clamp(38px, 2.9vw, 48px);
  padding:            0 clamp(6px, 0.5vw, 10px) 0 clamp(10px, 0.85vw, 14px);
  background:         #f9f8f5;
  border:             1px solid #e8e6e0;
  border-radius:      8px;
  font-size:          clamp(13px, 0.95vw, 15px);
  color:              var(--muse-text-primary);
  font-family:        inherit;
  outline:            none;
  transition:         border-color 0.15s, box-shadow 0.15s;
  appearance:         auto;
  -webkit-appearance: auto;
}

.inputNumber::-webkit-inner-spin-button,
.inputNumber::-webkit-outer-spin-button { opacity: 1; height: 100%; }
.inputNumber:hover { border-color: var(--muse-gold); }
.inputNumber:focus { border-color: var(--muse-gold); box-shadow: 0 0 0 2px rgba(201,168,76,0.15); }

/* ── Native select ───────────────────────────────────────────── */
.selectWrapper {
  position: relative;
  width:    100%;
}

.select, .modeSelect {
  appearance:         none;
  -webkit-appearance: none;
  width:         100%;
  height:        clamp(38px, 2.9vw, 48px);
  padding:       0 clamp(32px, 2.2vw, 44px) 0 clamp(10px, 0.85vw, 14px);
  background:    #f9f8f5;
  border:        1px solid #e8e6e0;
  border-radius: 8px;
  font-size:     clamp(13px, 0.95vw, 15px);
  color:         var(--muse-text-primary);
  font-family:   inherit;
  outline:       none;
  cursor:        pointer;
  transition:    border-color 0.15s, box-shadow 0.15s;
}

.select:hover, .modeSelect:hover { border-color: var(--muse-gold); }
.select:focus, .modeSelect:focus { border-color: var(--muse-gold); box-shadow: 0 0 0 2px rgba(201,168,76,0.15); }

.selectChevron {
  position:       absolute;
  right:          clamp(10px, 0.85vw, 14px);
  top:            50%;
  transform:      translateY(-50%);
  color:          #9ca3af;
  font-size:      clamp(10px, 0.72vw, 12px);
  pointer-events: none;
  user-select:    none;
  line-height:    1;
}

/* ── Toggle row ──────────────────────────────────────────────── */
.toggleRow {
  display:         flex;
  align-items:     center;
  justify-content: space-between;
  gap:             12px;
}

.toggleLabel {
  font-size:   clamp(12px, 0.88vw, 14px);
  color:       var(--muse-text-secondary);
  line-height: 1;
}

/* ── Bottom actions ──────────────────────────────────────────── */
.actions {
  display:     flex;
  align-items: center;
  gap:         clamp(10px, 0.85vw, 14px);
  flex-wrap:   wrap;
}

.saveBtn {
  display:       inline-flex;
  align-items:   center;
  gap:           7px;
  padding:       clamp(10px, 0.85vw, 13px) clamp(16px, 1.3vw, 24px);
  background:    var(--muse-gold);
  color:         #1a1f2e;
  font-size:     clamp(13px, 0.9vw, 14px);
  font-weight:   600;
  border:        none;
  border-radius: 8px;
  cursor:        pointer;
  font-family:   inherit;
  transition:    background 0.15s, transform 0.1s;
  white-space:   nowrap;
}

.saveBtn:hover { background: var(--muse-gold-dark); transform: translateY(-1px); }

.exportBtn {
  display:       inline-flex;
  align-items:   center;
  gap:           7px;
  padding:       clamp(10px, 0.85vw, 13px) clamp(16px, 1.3vw, 24px);
  background:    var(--muse-card-bg);
  color:         var(--muse-text-primary);
  font-size:     clamp(13px, 0.9vw, 14px);
  font-weight:   500;
  border:        1px solid var(--muse-card-border);
  border-radius: 8px;
  cursor:        pointer;
  font-family:   inherit;
  transition:    border-color 0.15s, transform 0.1s;
  white-space:   nowrap;
}

.exportBtn:hover { border-color: var(--muse-gold); transform: translateY(-1px); }

.attribution {
  font-size:   clamp(11px, 0.75vw, 12px);
  color:       var(--muse-text-muted);
  margin-left: auto;
  white-space: nowrap;
}

/* ── Tablet (768–1023px) ──────────────────────────────────────── */
@media (max-width: 1023px) {
  .layout {
    grid-template-columns: 1fr;
  }

  .resultsCol { order: 2; }
  .formCol    { order: 1; }

  .attribution {
    margin-left: 0;
    width:       100%;
  }
}

/* ── Mobile (<768px) ─────────────────────────────────────────── */
@media (max-width: 767px) {
  .page { gap: 16px; }

  .pageTitle { font-size: 20px; }

  .pageHeader {
    flex-direction: column;
    align-items:    stretch;
  }

  .inputNumber,
  .select,
  .modeSelect {
    font-size: 16px;
  }

  .actions {
    flex-direction: column;
    align-items:    stretch;
  }

  .saveBtn, .exportBtn {
    justify-content: center;
    width:           100%;
  }

  .attribution {
    text-align:  center;
    margin-left: 0;
  }
}
</file>

