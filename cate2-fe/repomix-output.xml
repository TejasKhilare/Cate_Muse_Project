// src/muse/pages/index.ts
export { DashboardPage }           from './DashboardPage/DashboardPage';
export { NewProposalPage }         from './NewProposalPage/NewProposalPage';
export { ProposalsPage }           from './ProposalsPage/ProposalsPage';
