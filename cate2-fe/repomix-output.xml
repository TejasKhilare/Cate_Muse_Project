/* src/muse/components/layout/MuseSidebar/MuseSidebar.module.css */

/* ── Shell ───────────────────────────────────────────────────── */
.sidebar {
  display:        flex;
  flex-direction: column;
  /*
   * clamp(240px, 15vw, 340px)
   * At 1024px viewport → 15vw = 153px → clamp floors at 240px
   * At 1440px viewport → 15vw = 216px → clamp floors at 240px
   * At 1600px viewport → 15vw = 240px → exact match
   * At 1920px viewport → 15vw = 288px → scales up
   * At 2560px viewport → 15vw = 384px → clamp caps at 340px
   * Sidebar grows naturally with viewport width.
   */
  width:          clamp(240px, 15vw, 340px);
  min-height:     100vh;
  background:     var(--muse-sidebar-bg);
  flex-shrink:    0;
  position:       fixed;
  top:            0;
  left:           0;
  bottom:         0;
  z-index:        100;
  overflow-y:     auto;
  overflow-x:     hidden;
  transition:     transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Desktop: always visible */
@media (min-width: 1024px) {
  .sidebar {
    transform: none !important;
  }
}

/* Tablet/Mobile: drawer */
@media (max-width: 1023px) {
  .sidebar {
    width:     240px; /* fixed on drawer — clamp based on viewport makes no sense when it overlays */
    transform: translateX(-100%);
  }

  .sidebarOpen {
    transform: translateX(0);
  }
}

/* ── Logo area ───────────────────────────────────────────────── */
.logoArea {
  padding:       clamp(18px, 1.6vw, 32px) clamp(16px, 1.4vw, 28px);
