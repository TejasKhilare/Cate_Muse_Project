import { useNewProposal } from '@/muse/hooks/new-proposal/useNewProposal';
import styles from './NewProposalPage.module.css';

export const NewProposalPage = () => {
  const {
    form,
    updateField,
    isSubmitting,
    isSavingDraft,
    handleCreate,
    handleSaveDraft,
  } = useNewProposal();

  return (
    <MuseLayout>
      <div className={styles.page}>

        {/* ── Page header ── */}
